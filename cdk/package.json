{
  "name": "ask-my-docs-cdk",
  "version": "1.0.0",
  "description": "CDK infrastructure for Ask My Docs",
  "main": "bin/app.js",
  "scripts": {
    "build":   "tsc",
    "watch":   "tsc -w",
    "test":    "jest",
    "cdk":     "cdk",
    "synth":   "cdk synth",
    "diff":    "cdk diff",
    "deploy":  "cdk deploy --require-approval never",
    "destroy": "cdk destroy --force",
    "lint":    "eslint . --ext .ts"
  },
  "devDependencies": {
    "@types/jest":         "^29.5.0",
    "@types/node":         "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser":        "^6.0.0",
    "aws-cdk":             "^2.130.0",
    "eslint":              "^8.0.0",
    "jest":                "^29.5.0",
    "ts-jest":             "^29.1.0",
    "typescript":          "^5.0.0"
  },
  "dependencies": {
    "aws-cdk-lib":     "^2.130.0",
    "constructs":      "^10.0.0",
    "source-map-support": "^0.5.21"
  },
  "jest": {
    "testEnvironment":  "node",
    "roots":            ["<rootDir>/test"],
    "testMatch":        ["**/*.test.ts"],
    "transform":        { "^.+\\.tsx?$": "ts-jest" }
  }
}
